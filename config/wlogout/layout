{
  "label" : "lock",
  "action" : "loginctl lock-session",
  "text" : "Lock",
  "keybind" : "l"
}
{
  "label" : "hibernate",
  "action" : "notify-send 'systemctl hibernate'",
  "text" : "Hibernate",
  "keybind" : "h"
}
{
  "label" : "logout",
  "action" : "notify-send 'sleep 1; hyprctl dispatch exit'",
  "text" : "Logout",
  "keybind" : "e"
}
{
  "label" : "shutdown",
  "action" : "systemctl poweroff",
  "text" : "Shutdown",
  "keybind" : "s"
}
{
  "label" : "suspend",
  "action" : "notify-send 'systemctl suspend'",
  "text" : "Suspend",
  "keybind" : "u"
}
{
  "label" : "reboot",
  "action" : "systemctl reboot",
  "text" : "Reboot",
  "keybind" : "r"
}
